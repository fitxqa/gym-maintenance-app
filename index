<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#7c3aed">
    <title>Gym Equipment Maintenance</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
            padding-bottom: 80px;
        }

        .container {
            max-width: 700px;
            margin: 0 auto;
        }

        /* Header */
        .header {
            background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%);
            color: white;
            padding: 28px 24px;
            border-radius: 32px;
            margin-bottom: 24px;
            box-shadow: 0 20px 35px -10px rgba(0,0,0,0.2);
            position: relative;
            overflow: hidden;
        }

        .header::before {
            content: "🔧";
            position: absolute;
            right: -20px;
            bottom: -20px;
            font-size: 100px;
            opacity: 0.1;
            transform: rotate(-15deg);
        }

        .header h1 {
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }

        .header p {
            font-size: 14px;
            opacity: 0.95;
        }

        .stats {
            display: flex;
            gap: 12px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .stat-badge {
            background: rgba(255,255,255,0.25);
            backdrop-filter: blur(10px);
            padding: 8px 16px;
            border-radius: 40px;
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* Card Style */
        .card {
            background: white;
            border-radius: 32px;
            padding: 24px;
            margin-bottom: 24px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: transform 0.2s;
        }

        .card:hover {
            transform: translateY(-2px);
        }

        .card-title {
            font-size: 20px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-left: 5px solid;
            border-image: linear-gradient(135deg, #f59e0b, #ef4444);
            border-image-slice: 1;
            padding-left: 15px;
        }

        /* Form Styles */
        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 8px;
        }

        label .required {
            color: #ef4444;
        }

        input, select, textarea {
            width: 100%;
            padding: 14px 16px;
            font-size: 16px;
            border: 2px solid #e5e7eb;
            border-radius: 20px;
            background: white;
            transition: all 0.3s;
            font-family: inherit;
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: #f59e0b;
            box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.1);
        }

        /* Priority Badges */
        .priority-high {
            background: linear-gradient(135deg, #fee2e2, #fecaca);
            color: #991b1b;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
        }

        .priority-medium {
            background: linear-gradient(135deg, #fed7aa, #fde68a);
            color: #92400e;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
        }

        .priority-low {
            background: linear-gradient(135deg, #d1fae5, #a7f3d0);
            color: #065f46;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
        }

        /* Time Slots */
        .time-slots {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 12px;
            margin-top: 12px;
        }

        .time-slot {
            background: linear-gradient(135deg, #f9fafb, #ffffff);
            border: 2px solid #e5e7eb;
            border-radius: 20px;
            padding: 12px 8px;
            text-align: center;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .time-slot.selected {
            background: linear-gradient(135deg, #f59e0b, #ef4444);
            color: white;
            border-color: #f59e0b;
            transform: scale(0.98);
        }

        .time-slot.booked {
            background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
            border-color: #d1d5db;
            color: #9ca3af;
            cursor: not-allowed;
            opacity: 0.6;
            text-decoration: line-through;
        }

        /* Button */
        .btn {
            width: 100%;
            padding: 16px;
            font-size: 16px;
            font-weight: 700;
            border: none;
            border-radius: 28px;
            cursor: pointer;
            transition: all 0.3s;
            background: linear-gradient(135deg, #f59e0b, #ef4444);
            color: white;
        }

        .btn:active {
            transform: scale(0.98);
        }

        /* Maintenance Request List */
        .request-item {
            background: linear-gradient(135deg, #f9fafb, #ffffff);
            border-radius: 24px;
            padding: 16px;
            margin-bottom: 12px;
            border-left: 5px solid;
            transition: all 0.3s;
        }

        .request-item:hover {
            transform: translateX(5px);
        }

        .request-equipment {
            font-weight: 800;
            font-size: 16px;
            margin-bottom: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }

        .request-details {
            font-size: 13px;
            color: #6b7280;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 10px;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
        }

        .status-pending {
            background: linear-gradient(135deg, #fef3c7, #fde68a);
            color: #92400e;
        }

        .status-completed {
            background: linear-gradient(135deg, #d1fae5, #a7f3d0);
            color: #065f46;
        }

        .complete-btn {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            margin-top: 10px;
            margin-right: 8px;
            cursor: pointer;
        }

        .cancel-btn {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            margin-top: 10px;
            cursor: pointer;
        }

        /* Alerts */
        .alert {
            padding: 14px 18px;
            border-radius: 24px;
            margin-bottom: 20px;
            font-size: 14px;
            font-weight: 500;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from {
                transform: translateY(-20px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .alert-success {
            background: linear-gradient(135deg, #d1fae5, #a7f3d0);
            color: #065f46;
            border-left: 4px solid #10b981;
        }

        .alert-error {
            background: linear-gradient(135deg, #fee2e2, #fecaca);
            color: #991b1b;
            border-left: 4px solid #ef4444;
        }

        .empty-state {
            text-align: center;
            padding: 50px 20px;
            color: #9ca3af;
            background: linear-gradient(135deg, #f9fafb, #ffffff);
            border-radius: 24px;
        }

        .time-range-info {
            background: linear-gradient(135deg, #fef3c7, #fde68a);
            padding: 10px 16px;
            border-radius: 20px;
            font-size: 12px;
            color: #92400e;
            margin-bottom: 15px;
            text-align: center;
            font-weight: 600;
        }

        .date-display {
            margin-top: 18px;
            font-size: 14px;
            font-weight: 600;
            background: rgba(255,255,255,0.2);
            display: inline-block;
            padding: 8px 18px;
            border-radius: 40px;
            backdrop-filter: blur(10px);
        }

        /* Tablet & Mobile Responsive */
        @media (max-width: 768px) {
            body {
                padding: 16px;
            }
            
            .header h1 {
                font-size: 24px;
            }
            
            .card {
                padding: 20px;
            }
            
            .time-slots {
                grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
                gap: 10px;
            }
        }

        @media (max-width: 480px) {
            body {
                padding: 12px;
            }
            
            .header {
                padding: 20px 18px;
            }
            
            .header h1 {
                font-size: 22px;
            }
            
            .stats {
                gap: 8px;
            }
            
            .stat-badge {
                font-size: 11px;
                padding: 6px 12px;
            }
            
            .card {
                padding: 16px;
            }
            
            .card-title {
                font-size: 18px;
            }
            
            .time-slots {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .time-slot {
                padding: 10px 6px;
                font-size: 11px;
            }
            
            .btn {
                padding: 14px;
            }
        }

        /* Scrollbar Styling */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #f59e0b, #ef4444);
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>🔧 Gym Equipment Maintenance</h1>
            <p>Fast & reliable repair scheduling</p>
            <div class="stats">
                <div class="stat-badge" id="pendingCount">
                    ⏳ Pending: 0
                </div>
                <div class="stat-badge" id="todayCount">
                    📅 Today: 0
                </div>
                <div class="stat-badge" id="highPriorityCount">
                    🔴 High Priority: 0
                </div>
            </div>
            <div class="date-display" id="currentDate"></div>
        </div>

        <!-- Alert Container -->
        <div id="alertContainer"></div>

        <!-- Maintenance Request Form -->
        <div class="card">
            <div class="card-title">
                🛠️ New Maintenance Request
            </div>
            
            <div class="form-group">
                <label>Equipment Name <span class="required">*</span></label>
                <select id="equipmentType">
                    <option value="Treadmill">🏃 Treadmill</option>
                    <option value="Elliptical">🚶 Elliptical Machine</option>
                    <option value="Stationary Bike">🚲 Stationary Bike</option>
                    <option value="Rowing Machine">🚣 Rowing Machine</option>
                    <option value="Leg Press">🦵 Leg Press</option>
                    <option value="Chest Press">💪 Chest Press Machine</option>
                    <option value="Lat Pulldown">📊 Lat Pulldown</option>
                    <option value="Free Weights">🏋️ Free Weights / Dumbbells</option>
                    <option value="Cable Machine">🔗 Cable Crossover</option>
                    <option value="Other">🔧 Other Equipment</option>
                </select>
            </div>

            <div class="form-group">
                <label>Equipment ID / Location <span class="required">*</span></label>
                <input type="text" id="equipmentId" placeholder="e.g., TREAD-01, Zone A, Near Windows">
            </div>

            <div class="form-group">
                <label>Issue Description <span class="required">*</span></label>
                <textarea id="issueDesc" rows="2" placeholder="Describe the problem... (e.g., noisy belt, screen not working, hydraulic issue)"></textarea>
            </div>

            <div class="form-group">
                <label>Priority Level <span class="required">*</span></label>
                <select id="priority">
                    <option value="High">🔴 High - Equipment completely down / Safety hazard</option>
                    <option value="Medium">🟠 Medium - Partially working / Affects user experience</option>
                    <option value="Low">🟢 Low - Minor issue / Cosmetic / Routine maintenance</option>
                </select>
            </div>

            <div class="form-group">
                <label>Your Name <span class="required">*</span></label>
                <input type="text" id="requestedBy" placeholder="Enter your full name">
            </div>

            <div class="form-group">
                <label>Mobile Number <span class="required">*</span></label>
                <input type="tel" id="mobileNumber" placeholder="📱 Enter your mobile number (e.g., 9876543210)">
                <div style="font-size: 11px; color: #6b7280; margin-top: 6px;">
                    We'll send confirmation to this number
                </div>
            </div>

            <div class="form-group">
                <label>Preferred Time Slot <span class="required">*</span> (8:00 AM - 11:00 PM)</label>
                <div class="time-range-info">
                    🕐 1-hour maintenance slots | 8 AM to 11 PM
                </div>
                <div class="time-slots" id="timeSlots">
                    <!-- Time slots will be generated here -->
                </div>
            </div>

            <div class="form-group">
                <label>Additional Notes</label>
                <textarea id="notes" rows="2" placeholder="Special instructions, tools needed, access information..."></textarea>
            </div>

            <button class="btn" onclick="submitMaintenanceRequest()">
                📋 Submit Maintenance Request
            </button>
        </div>

        <!-- Today's Maintenance Schedule -->
        <div class="card">
            <div class="card-title">
                📅 Today's Schedule
            </div>
            <div id="maintenanceList">
                <!-- Maintenance requests will appear here -->
            </div>
        </div>
    </div>

    <script>
        // Available time slots from 8:00 AM to 11:00 PM
        const TIME_SLOTS = [
            "08:00 AM - 09:00 AM", "09:00 AM - 10:00 AM", "10:00 AM - 11:00 AM", "11:00 AM - 12:00 PM",
            "12:00 PM - 01:00 PM", "01:00 PM - 02:00 PM", "02:00 PM - 03:00 PM", "03:00 PM - 04:00 PM",
            "04:00 PM - 05:00 PM", "05:00 PM - 06:00 PM", "06:00 PM - 07:00 PM", "07:00 PM - 08:00 PM",
            "08:00 PM - 09:00 PM", "09:00 PM - 10:00 PM", "10:00 PM - 11:00 PM"
        ];

        const STORAGE_KEY = 'gym_maintenance_requests';

        function getTodayDate() {
            const today = new Date();
            return today.toISOString().split('T')[0];
        }

        function formatDate() {
            const today = new Date();
            const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            return today.toLocaleDateString('en-US', options);
        }

        function loadRequests() {
            const stored = localStorage.getItem(STORAGE_KEY);
            if (!stored) return {};
            return JSON.parse(stored);
        }

        function saveRequests(requests) {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(requests));
        }

        function getTodayRequests() {
            const allRequests = loadRequests();
            const today = getTodayDate();
            return allRequests[today] || [];
        }

        function getAllPendingRequests() {
            const allRequests = loadRequests();
            let pending = 0;
            for (const date in allRequests) {
                pending += allRequests[date].filter(r => r.status !== 'Completed').length;
            }
            return pending;
        }

        function getHighPriorityCount() {
            const allRequests = loadRequests();
            let highCount = 0;
            for (const date in allRequests) {
                highCount += allRequests[date].filter(r => r.priority === 'High' && r.status !== 'Completed').length;
            }
            return highCount;
        }

        function getBookedSlots() {
            const todayRequests = getTodayRequests();
            return todayRequests.filter(r => r.status !== 'Completed').map(req => req.timeSlot);
        }

        function renderTimeSlots() {
            const bookedSlots = getBookedSlots();
            const selectedSlot = document.getElementById('selectedTimeSlot')?.value || '';
            
            const container = document.getElementById('timeSlots');
            container.innerHTML = '';
            
            TIME_SLOTS.forEach(slot => {
                const slotDiv = document.createElement('div');
                slotDiv.className = 'time-slot';
                if (bookedSlots.includes(slot)) {
                    slotDiv.classList.add('booked');
                    slotDiv.innerHTML = `${slot}<br><span style="font-size:10px">🔧 Booked</span>`;
                } else {
                    slotDiv.innerHTML = slot;
                    if (selectedSlot === slot) {
                        slotDiv.classList.add('selected');
                    }
                }
                
                if (!bookedSlots.includes(slot)) {
                    slotDiv.onclick = () => selectTimeSlot(slot);
                }
                
                container.appendChild(slotDiv);
            });
        }

        function selectTimeSlot(slot) {
            document.querySelectorAll('.time-slot').forEach(el => {
                el.classList.remove('selected');
            });
            
            event.target.closest('.time-slot').classList.add('selected');
            
            if (!window.selectedTimeSlotValue) {
                window.selectedTimeSlotValue = document.createElement('input');
                window.selectedTimeSlotValue.type = 'hidden';
                window.selectedTimeSlotValue.id = 'selectedTimeSlot';
                document.body.appendChild(window.selectedTimeSlotValue);
            }
            window.selectedTimeSlotValue.value = slot;
        }

        function getSelectedTimeSlot() {
            const hiddenInput = document.getElementById('selectedTimeSlot');
            return hiddenInput ? hiddenInput.value : '';
        }

        function showAlert(message, type = 'success') {
            const alertContainer = document.getElementById('alertContainer');
            alertContainer.innerHTML = `
                <div class="alert alert-${type}">
                    ${type === 'success' ? '✅' : '⚠️'} ${message}
                </div>
            `;
            
            setTimeout(() => {
                alertContainer.innerHTML = '';
            }, 3000);
        }

        function validateMobileNumber(mobile) {
            const mobileRegex = /^[0-9]{7,15}$/;
            return mobileRegex.test(mobile);
        }

        function submitMaintenanceRequest() {
            const equipmentType = document.getElementById('equipmentType').value;
            const equipmentId = document.getElementById('equipmentId').value.trim();
            const issueDesc = document.getElementById('issueDesc').value.trim();
            const priority = document.getElementById('priority').value;
            const requestedBy = document.getElementById('requestedBy').value.trim();
            const mobileNumber = document.getElementById('mobileNumber').value.trim();
            const notes = document.getElementById('notes').value;
            const selectedTimeSlot = getSelectedTimeSlot();
            
            if (!equipmentId) {
                showAlert('Please enter equipment ID or location', 'error');
                return;
            }
            
            if (!issueDesc) {
                showAlert('Please describe the issue', 'error');
                return;
            }
            
            if (!requestedBy) {
                showAlert('Please enter your name', 'error');
                return;
            }
            
            if (!mobileNumber) {
                showAlert('Please enter your mobile number', 'error');
                return;
            }
            
            if (!validateMobileNumber(mobileNumber)) {
                showAlert('Please enter a valid mobile number (7-15 digits)', 'error');
                return;
            }
            
            if (!selectedTimeSlot) {
                showAlert('Please select a time slot', 'error');
                return;
            }
            
            const bookedSlots = getBookedSlots();
            if (bookedSlots.includes(selectedTimeSlot)) {
                showAlert('This time slot is already booked!', 'error');
                renderTimeSlots();
                return;
            }
            
            const maintenanceRequest = {
                id: Date.now().toString(),
                equipmentType: equipmentType,
                equipmentId: equipmentId,
                issueDesc: issueDesc,
                priority: priority,
                requestedBy: requestedBy,
                mobileNumber: mobileNumber,
                timeSlot: selectedTimeSlot,
                notes: notes,
                status: 'Pending',
                submittedAt: new Date().toISOString(),
                completedAt: null
            };
            
            const allRequests = loadRequests();
            const today = getTodayDate();
            
            if (!allRequests[today]) {
                allRequests[today] = [];
            }
            
            allRequests[today].push(maintenanceRequest);
            saveRequests(allRequests);
            
            showAlert(`✓ Request submitted for ${selectedTimeSlot}!`, 'success');
            
            document.getElementById('equipmentId').value = '';
            document.getElementById('issueDesc').value = '';
            document.getElementById('requestedBy').value = '';
            document.getElementById('mobileNumber').value = '';
            document.getElementById('notes').value = '';
            document.getElementById('equipmentType').value = 'Treadmill';
            document.getElementById('priority').value = 'Medium';
            
            const hiddenInput = document.getElementById('selectedTimeSlot');
            if (hiddenInput) hiddenInput.value = '';
            
            renderTimeSlots();
            displayTodayMaintenance();
            updateStats();
        }
        
        function completeMaintenance(requestId) {
            if (confirm('✅ Mark this maintenance as completed?')) {
                const allRequests = loadRequests();
                const today = getTodayDate();
                
                if (allRequests[today]) {
                    const request = allRequests[today].find(r => r.id === requestId);
                    if (request) {
                        request.status = 'Completed';
                        request.completedAt = new Date().toISOString();
                        saveRequests(allRequests);
                        renderTimeSlots();
                        displayTodayMaintenance();
                        updateStats();
                        showAlert(`✓ Completed: ${request.equipmentType}`, 'success');
                    }
                }
            }
        }
        
        function cancelRequest(requestId) {
            if (confirm('❌ Cancel this maintenance request?')) {
                const allRequests = loadRequests();
                const today = getTodayDate();
                
                if (allRequests[today]) {
                    allRequests[today] = allRequests[today].filter(r => r.id !== requestId);
                    
                    if (allRequests[today].length === 0) {
                        delete allRequests[today];
                    }
                    
                    saveRequests(allRequests);
                    renderTimeSlots();
                    displayTodayMaintenance();
                    updateStats();
                    showAlert('Request cancelled', 'success');
                }
            }
        }
        
        function getPriorityClass(priority) {
            switch(priority) {
                case 'High': return 'priority-high';
                case 'Medium': return 'priority-medium';
                case 'Low': return 'priority-low';
                default: return '';
            }
        }
        
        function getStatusClass(status) {
            switch(status) {
                case 'Pending': return 'status-pending';
                case 'Completed': return 'status-completed';
                default: return '';
            }
        }
        
        function displayTodayMaintenance() {
            const todayRequests = getTodayRequests();
            const container = document.getElementById('maintenanceList');
            
            if (todayRequests.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        🔧 No maintenance requests for today
                        <br><span style="font-size: 12px;">Schedule your first request above</span>
                    </div>
                `;
                return;
            }
            
            const sortedRequests = [...todayRequests].sort((a, b) => {
                return a.timeSlot.localeCompare(b.timeSlot);
            });
            
            container.innerHTML = sortedRequests.map(req => `
                <div class="request-item" style="border-left-color: ${req.priority === 'High' ? '#ef4444' : (req.priority === 'Medium' ? '#f59e0b' : '#10b981')}">
                    <div class="request-equipment">
                        <span>🔧 ${escapeHtml(req.equipmentType)}</span>
                        <span class="${getPriorityClass(req.priority)}">${req.priority}</span>
                    </div>
                    <div style="font-size: 14px; font-weight: 600; color: #374151; margin-top: 5px;">
                        📍 ${escapeHtml(req.equipmentId)}
                    </div>
                    <div style="font-size: 13px; color: #6b7280; margin-top: 6px;">
                        ⚠️ ${escapeHtml(req.issueDesc)}
                    </div>
                    <div class="request-details">
                        <span>⏰ ${req.timeSlot}</span>
                        <span>👤 ${escapeHtml(req.requestedBy)}</span>
                        <span>📱 ${escapeHtml(req.mobileNumber)}</span>
                        <span class="status-badge ${getStatusClass(req.status)}">${req.status}</span>
                    </div>
                    ${req.notes ? `<div style="font-size:12px; color:#6b7280; margin-top:6px;">📝 ${escapeHtml(req.notes)}</div>` : ''}
                    ${req.status !== 'Completed' ? `
                        <button class="complete-btn" onclick="completeMaintenance('${req.id}')">✓ Mark Completed</button>
                        <button class="cancel-btn" onclick="cancelRequest('${req.id}')">✗ Cancel</button>
                    ` : `
                        <div style="font-size: 12px; color: #10b981; margin-top: 8px;">✅ Completed on ${new Date(req.completedAt).toLocaleTimeString()}</div>
                    `}
                </div>
            `).join('');
        }
        
        function updateStats() {
            const pendingCount = getAllPendingRequests();
            const todayCount = getTodayRequests().length;
            const highPriorityCount = getHighPriorityCount();
            
            document.getElementById('pendingCount').innerHTML = `⏳ Pending: ${pendingCount}`;
            document.getElementById('todayCount').innerHTML = `📅 Today: ${todayCount}`;
            document.getElementById('highPriorityCount').innerHTML = `🔴 High Priority: ${highPriorityCount}`;
        }
        
        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }
        
        function init() {
            document.getElementById('currentDate').innerHTML = `📆 ${formatDate()}`;
            renderTimeSlots();
            displayTodayMaintenance();
            updateStats();
        }
        
        init();
    </script>
</body>
</html>
